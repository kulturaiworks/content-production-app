        {
            "parameters": {
                "jsCode": "const PERSONAS = {\n  'Raga Plus ID': { voice: 'Profesional namun engaging, berita olahraga', tone: 'Energik, passionate, informatif', audience: 'Fans sepakbola 18-35 tahun', style: 'To the point, emosional saat big moments, sertakan fakta', hashtag: '#sepakbola #timnas #liga1' },\n  'Red Talks ID': { voice: 'Santai, seperti ngobrol teman', tone: 'Kasual, friendly, humor', audience: 'Anak muda 18-30 suka gossip', style: 'Storytelling, bahasa gaul, ajak interaksi', hashtag: '#trending #viral' },\n  'Kultur AI': { voice: 'Edukatif tentang teknologi AI', tone: 'Profesional tapi accessible', audience: 'Tech enthusiasts 20-40 tahun', style: 'Analogi sederhana, future-focused, manfaat praktis', hashtag: '#AI #teknologi' },\n  'Bersama Teddy': { voice: 'Personal, motivational', tone: 'Inspiratif, supportive, empati', audience: '25-45 tahun cari motivasi', style: 'Personal story, refleksi, actionable advice', hashtag: '#motivasi #inspirasi' },\n  'Kami Meutya': { voice: 'Feminine, empowering', tone: 'Warm, supportive, authentic', audience: 'Perempuan 20-35, lifestyle & career', style: 'Relatable, empowering, honest', hashtag: '#perempuan #lifestyle' },\n  'Bocahe Kaesang': { voice: 'Fun, playful, anak muda', tone: 'Ceria, lucu, santai', audience: 'Gen Z 15-30 tahun', style: 'Bahasa gaul, meme-able, banyak emoji', hashtag: '#genZ #FYP' },\n  'Team Pur': { voice: 'Energik, community-driven', tone: 'Enthusiastic, loyal', audience: 'Fans klub, semua usia', style: 'Solidaritas, bangga achievements', hashtag: '#teampur #solidarity' },\n  'Motorell': { voice: 'Maskulin, teknis otomotif', tone: 'Knowledgeable, excited', audience: 'Pria 20-45 pecinta motor', style: 'Spesifikasi teknis, review jujur', hashtag: '#motor #otomotif' },\n  'Fox Populi': { voice: 'Cerdas, kritis, sarkastis', tone: 'Witty, sharp, observant', audience: 'Educated millennials 25-40', style: 'Analisis tajam, humor cerdas', hashtag: '#politik #sosial' },\n  'Whats On': { voice: 'Update event/hiburan', tone: 'Excited, FOMO-inducing', audience: 'Anak muda 18-35 aktif socializing', style: 'Quick info, ajak action', hashtag: '#event #Jakarta' },\n  'Dakwah AI': { voice: 'Religius, bijaksana', tone: 'Respectful, wise, inspirational', audience: 'Muslim 20-50 belajar agama', style: 'Dalil + penjelasan, inspirasi spiritual', hashtag: '#dakwah #islamic' },\n  'Wisato ID': { voice: 'Adventurous, wanderlust', tone: 'Excited, descriptive', audience: 'Traveler 20-40 tahun', style: 'Deskripsi vivid, tips praktis', hashtag: '#travel #explorenusantara' },\n  'Maxi Theory': { voice: 'Intelektual, thought-provoking', tone: 'Analytical, questioning', audience: 'Thinkers 25-50 tahun', style: 'Deep analysis, perspektif beragam', hashtag: '#philosophy #deepthoughts' }\n};\n\nconst input = $input.first().json;\nconst persona = PERSONAS[input.body?.media || input.media] || PERSONAS['Red Talks ID'];\nconst media = input.body?.media || input.media;\nconst model = input.body?.model || input.model;\nconst content = input.body?.content || input.content;\nconst input_type = input.body?.input_type || input.input_type;\n\nconst system_prompt = `Kamu copywriter ahli untuk ${media}.\n\nVoice: ${persona.voice}\nTone: ${persona.tone}\nAudience: ${persona.audience}\nStyle: ${persona.style}\n\nBuat:\n1. 3 headline clickbait (max 60 karakter)\n2. 2 caption Instagram (150-200 kata, include hashtags ${persona.hashtag})\n\nOUTPUT JSON ONLY (tanpa markdown code block):\n{\"headlines\": [\"...\", \"...\", \"...\"], \"captions\": [\"...\", \"...\"]}\n\nPENTING: Bahasa Indonesia, gunakan HANYA fakta dari artikel, jangan halusinasi!`;\n\nreturn [{\n  json: {\n    media,\n    model,\n    content,\n    input_type,\n    persona,\n    system_prompt\n  }\n}];"
            },
            "id": "f2a2a2a2-2222-2222-2222-222222222222",
            "name": "Persona Mapper",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                440,
                300
            ]
        },
        {
            "parameters": {
                "rules": {
                    "values": [
                        {
                            "conditions": {
                                "options": {
                                    "caseSensitive": true,
                                    "leftValue": "",
                                    "typeValidation": "strict"
                                },
                                "conditions": [
                                    {
                                        "id": "r1",
                                        "leftValue": "={{ $json.model }}",
                                        "rightValue": "chatgpt-jina",
                                        "operator": {
                                            "type": "string",
                                            "operation": "equals"
                                        }
                                    }
                                ]
