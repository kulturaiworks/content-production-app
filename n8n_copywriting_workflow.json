                "jsonBody": "={{ JSON.stringify({ model: 'sonar', temperature: 0.7, messages: [{ role: 'system', content: $json.system_prompt }, { role: 'user', content: 'Cari info terbaru lalu buatkan copywriting tentang: ' + $json.content }] }) }}",
                "options": {}
            },
            "id": "f8a8a8a8-8888-8888-8888-888888888888",
            "name": "Perplexity",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.2,
            "position": [
                860,
                440
            ]
        },
        {
            "parameters": {
                "jsCode": "const data = $input.first().json;\nlet text = '';\n\nif (data.choices && data.choices[0]) {\n  text = data.choices[0].message.content;\n} else if (data.message?.content) {\n  text = data.message.content;\n}\n\nlet result;\ntry {\n  const cleaned = text.replace(/```json\\n?/g, '').replace(/```/g, '').trim();\n  result = JSON.parse(cleaned);\n} catch(e) {\n  const match = text.match(/{[\\s\\S]*}/);\n  if (match) {\n    try { result = JSON.parse(match[0]); } catch(e2) {}\n  }\n}\n\nif (!result?.headlines || !result?.captions) {\n  result = {\n    headlines: ['Error: gagal parse', 'Coba lagi', 'Atau ganti model'],\n    captions: ['LLM response tidak valid. Coba lagi.']\n  };\n}\n\nreturn [{ json: result }];"
            },
